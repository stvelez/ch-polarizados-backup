# ─── MySQL Railway ────────────────────────────────────────────────────────────
MYSQL_PASSWORD=tu_password_aqui
MYSQL_SSL=true
MYSQL_SSL_VERIFY_SERVER_CERT=false
MYSQL_SSL_CA=

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Obtener con @BotFather en Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
# Obtener enviando un mensaje al bot y consultando:
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=987654321

# ─── Google Drive ─────────────────────────────────────────────────────────────
# ID de la carpeta donde se subirán los backups.
# Abrir la carpeta en Drive → la URL tiene el ID al final:
# https://drive.google.com/drive/folders/<FOLDER_ID>
GOOGLE_DRIVE_FOLDER_ID=1iFrQ3TdOPKYFORLTanqj3oCK4tWZT6IB

# ─── Cifrado GPG (opcional) ───────────────────────────────────────────────────
# Si se define, los backups se cifran con AES-256 antes de subir a Drive.
# Los archivos quedarán como .sql.gz.gpg
# Dejar vacío para desactivar el cifrado.
GPG_PASSPHRASE=
